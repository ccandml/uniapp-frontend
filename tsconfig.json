{
  "extends": "@vue/tsconfig/tsconfig.json",
  "compilerOptions": {
    // 严格模式（保留）  
    "noImplicitAny": true,
    "strictNullChecks": true,
    // TS 5 修复废弃选项（关键新增）  
    "verbatimModuleSyntax": true, // ✅ 替换 importsNotUsedAsValues  
    "noEmit": true, // ✅ 解锁 allowImportingTsExtensions  
    // TS 5 优化（完整）  
    "target": "ES2020",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "useDefineForClassFields": true,
    "skipLibCheck": true,
    // 原有（保留）  
    "jsx": "preserve",
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "types": [
      "@dcloudio/types",
      "miniprogram-api-typings",
      "@uni-helper/uni-app-types",
      "@uni-helper/uni-ui-types",
      "vite/client"
    ]
  },
  "vueCompilerOptions": {
    "plugins": [
      "@uni-helper/uni-app-types/volar-plugin"
    ]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.js",
    "**/*.vue.js"
  ]
}